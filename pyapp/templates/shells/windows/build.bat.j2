@echo off
REM Build script for {{ app_name }} Windows Stub
REM Requires: MinGW-w64 (g++), WebView2 Runtime (for running, not building)

echo Building {{ app_name }} stub...

REM Compile resource file
windres app_stub.rc -O coff -o app_stub.res
if %ERRORLEVEL% NEQ 0 (
    echo Warning: Resource compilation failed, building without resources
    set STUB_RES=
) else (
    set STUB_RES=app_stub.res
)

REM Compile stub (C++ with WebView2 + WinHTTP support)
g++ -o {{ app_name }}.exe app_stub.cpp %STUB_RES% ^
    -mwindows -O2 -s ^
    -lwinhttp -lole32 -loleaut32 -lshell32 -lgdi32 -lws2_32

if %ERRORLEVEL% EQU 0 (
    echo Done! {{ app_name }}.exe created successfully.
) else (
    echo Error: Compilation failed!
    exit /b 1
)
