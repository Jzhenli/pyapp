{% raw %}name: Build Windows App

on:
  push:
    tags:
      - '*-windows/v*'
      - '*-all/v*'
  workflow_dispatch:
    inputs:
      enable_nuitka:
        description: 'Enable Nuitka compilation'
        required: false
        type: boolean
        default: true

permissions:
  contents: read

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  build:
    runs-on: windows-latest
    timeout-minutes: 60
    steps:
      - uses: actions/checkout@v4
      - name: Read project config
        id: vars
        shell: bash
        run: |
          echo "app_name=$(grep '^name = ' pyproject.toml | head -1 | sed 's/.*"\(.*\)".*/\1/')" >> $GITHUB_OUTPUT
          echo "version=$(grep '^version = ' pyproject.toml | head -1 | sed 's/.*"\(.*\)".*/\1/')" >> $GITHUB_OUTPUT
          echo "python_version=$(grep 'python_version' pyproject.toml | head -1 | sed 's/.*"\(.*\)".*/\1/')" >> $GITHUB_OUTPUT
      - uses: actions/setup-python@v5
        with:
          python-version: ${{ steps.vars.outputs.python_version }}
      - name: Install pyapp
        run: pip install "pyapp-cli[compile] @ git+https://github.com/Jzhenli/pyapp.git"
      - name: Build
        run: pyapp build windows
      - name: Compile with Nuitka
        if: inputs.enable_nuitka != false
        run: pyapp compile windows
      - name: Package
        run: pyapp package windows
      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: ${{ steps.vars.outputs.app_name }}-${{ steps.vars.outputs.version }}-windows
          path: dist/*.zip
      - name: Summary
        if: always()
        shell: bash
        run: |
          echo "### Windows Build" >> $GITHUB_STEP_SUMMARY
          echo "- **App**: ${{ steps.vars.outputs.app_name }}" >> $GITHUB_STEP_SUMMARY
          echo "- **Version**: ${{ steps.vars.outputs.version }}" >> $GITHUB_STEP_SUMMARY
          echo "- **Nuitka**: ${{ inputs.enable_nuitka != false }}" >> $GITHUB_STEP_SUMMARY{% endraw %}

