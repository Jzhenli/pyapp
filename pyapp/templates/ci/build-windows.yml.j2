name: Build Windows

on:
  push:
    tags: ['v*']
  workflow_dispatch:

jobs:
  build:
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install pyapp
        run: pip install -e .

      - name: Build
        run: pyapp build windows

      - name: Install Nuitka
        run: pip install nuitka=={{ nuitka_version }} ordered-set zstandard

      - name: Setup MSVC
        uses: ilammy/msvc-dev-cmd@v1

      - name: Compile
        run: pyapp compile windows

      - name: Package
        run: pyapp package windows

      - uses: actions/upload-artifact@v4
        with:
          name: windows-package
          path: dist/*.zip
