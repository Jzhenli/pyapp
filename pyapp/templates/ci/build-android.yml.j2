{% raw %}name: Build Android App

on:
  push:
    tags:
      - '*-android/v*'
      - '*-all/v*'
  workflow_dispatch:
    inputs:
      architectures:
        description: 'Target architectures'
        required: false
        type: choice
        options: [arm64, arm32, 'arm64,arm32']
        default: 'arm64'
      enable_nuitka:
        description: 'Enable Nuitka compilation'
        required: false
        type: boolean
        default: true
      version:
        description: 'Version override (leave empty to use pyproject.toml)'
        required: false
        type: string

permissions:
  contents: read

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  config:
    runs-on: ubuntu-latest
    outputs:
      app_name: ${{ steps.vars.outputs.app_name }}
      app_module: ${{ steps.vars.outputs.app_module }}
      version: ${{ steps.vars.outputs.version }}
      python_version: ${{ steps.vars.outputs.python_version }}
      compile_matrix: ${{ steps.matrix.outputs.compile_matrix }}
      build_matrix: ${{ steps.matrix.outputs.build_matrix }}
    steps:
      - uses: actions/checkout@v4
      - name: Read project config
        id: vars
        env:
          VERSION_INPUT: ${{ inputs.version }}
        run: |
          # 确定版本号：tag 触发从 tag 提取，手动触发用输入值，否则从 pyproject.toml 读取
          if [[ "$GITHUB_REF" == refs/tags/* ]]; then
            VERSION="${GITHUB_REF#refs/tags/*/v}"
          elif [[ -n "$VERSION_INPUT" ]]; then
            VERSION="$VERSION_INPUT"
          else
            VERSION=$(grep '^version = ' pyproject.toml | head -1 | sed 's/.*"\(.*\)".*/\1/')
          fi
          # 回写 pyproject.toml，确保 pyapp build 读到正确版本（无覆盖时为空操作）
          [[ -n "$VERSION" ]] && sed -i "s/^version = \".*\"/version = \"$VERSION\"/" pyproject.toml
          echo "app_name=$(grep '^name = ' pyproject.toml | head -1 | sed 's/.*"\(.*\)".*/\1/')" >> $GITHUB_OUTPUT
          echo "version=$VERSION" >> $GITHUB_OUTPUT
          echo "app_module=$(grep 'app_module' pyproject.toml | head -1 | sed 's/.*"\(.*\)".*/\1/')" >> $GITHUB_OUTPUT
          echo "python_version=$(grep 'python_version' pyproject.toml | head -1 | sed 's/.*"\(.*\)".*/\1/')" >> $GITHUB_OUTPUT
      - name: Generate matrix
        id: matrix
        run: |
          ARCHS=$(echo "${{ inputs.architectures || 'arm64' }}" | tr -d ' ')
          COMPILE="" BUILD=""
          [[ "$ARCHS" == *"arm64"* ]] && COMPILE+='{"arch":"arm64","runs_on":"ubuntu-24.04-arm","termux_arch":"aarch64","android_abi":"arm64-v8a"},' && BUILD+='{"arch":"arm64","android_abi":"arm64-v8a","apk_arch":"arm64"},'
          [[ "$ARCHS" == *"arm32"* ]] && COMPILE+='{"arch":"arm32","runs_on":"ubuntu-24.04-arm","termux_arch":"arm","android_abi":"armeabi-v7a"},' && BUILD+='{"arch":"arm32","android_abi":"armeabi-v7a","apk_arch":"arm32"},'
          echo "compile_matrix=[${COMPILE%,}]" >> $GITHUB_OUTPUT
          echo "build_matrix=[${BUILD%,}]" >> $GITHUB_OUTPUT

  compile:
    needs: config
    if: inputs.enable_nuitka != false
    runs-on: ${{ matrix.runs_on }}
    timeout-minutes: 90
    strategy:
      fail-fast: false
      matrix:
        include: ${{ fromJson(needs.config.outputs.compile_matrix) }}
    steps:
      - uses: actions/checkout@v4
      - name: Inject version into source
        run: |
          INIT_FILE="src/${{ needs.config.outputs.app_module }}/__init__.py"
          [[ -f "$INIT_FILE" ]] && sed -i -E "s/__version__\s*=\s*[\"'][^\"']*[\"']/__version__ = \"${{ needs.config.outputs.version }}\"/" "$INIT_FILE" || true
      - name: Compile in Termux Docker
        run: |
          mkdir -p dist && chmod -R 777 dist src/
          
          # 将内联脚本通过标准输入传给 docker，避免生成临时文件和额外挂载
          docker run --rm -i -v "$PWD":/src \
            termux/termux-docker:${{ matrix.termux_arch }} \
            bash -s -- "${{ needs.config.outputs.python_version }}" "${{ needs.config.outputs.app_module }}" << 'EOF'
          
          #!/data/data/com.termux/files/usr/bin/bash
          set -e
          
          export PREFIX=/data/data/com.termux/files/usr
          export PATH=$PREFIX/bin:$PATH
          export HOME=/data/data/com.termux/files/home
          export TMPDIR=$PREFIX/tmp
          export LANG=en_US.UTF-8
          
          PY_VER="${1:-3.11}"
          APP_MODULE="${2:-demo}"
          PY_MINOR=$(echo "$PY_VER" | cut -d. -f1,2)
          echo ">>> Compiling $APP_MODULE with Python $PY_VER"
          
          # DNS 与镜像源加速
          echo -e "nameserver 8.8.8.8\nnameserver 8.8.4.4" > $PREFIX/etc/resolv.conf
          sed -i 's|https://packages.termux.dev/apt/termux-main|https://mirrors.ustc.edu.cn/termux/apt/termux-main|g; s|https://packages-cf.termux.dev/apt/termux-main|https://mirrors.ustc.edu.cn/termux/apt/termux-main|g' $PREFIX/etc/apt/sources.list
          
          # 安装系统依赖与编译工具
          apt update -yq && apt upgrade -yq
          apt install -yq tur-repo && apt update -yq
          apt install -yq python${PY_MINOR} ninja clang git patchelf ccache termux-elf-cleaner findutils
          
          # 软链接与 Nuitka 安装
          ln -sf $PREFIX/bin/python${PY_MINOR} $PREFIX/bin/python
          ln -sf $PREFIX/bin/pip${PY_MINOR} $PREFIX/bin/pip 2>/dev/null || true
          python --version
          pip install --upgrade pip
          pip install MarkupSafe==2.1.3 ordered-set==4.1.0 zstandard==0.23.0 nuitka==2.7.12
          
          # 执行编译
          mkdir -p /src/dist
          cd /src/src
          python -m nuitka --module "$APP_MODULE" --include-package="$APP_MODULE" \
            --output-dir=/src/dist --remove-output \
            --assume-yes-for-downloads --no-progressbar
          
          # 处理 ELF 产物
          cd /src/dist
          SO_FILE=$(ls ${APP_MODULE}.*.so 2>/dev/null | head -1)
          [ -z "$SO_FILE" ] && { echo "error: No .so produced"; exit 1; }
          mv "$SO_FILE" ${APP_MODULE}.so
          
          termux-elf-cleaner ${APP_MODULE}.so || true
          patchelf --set-rpath '' ${APP_MODULE}.so || true
          patchelf --replace-needed libpython${PY_MINOR}.so.1.0 libpython${PY_MINOR}.so ${APP_MODULE}.so || true
          echo ">>> Done. Final product: /src/dist/${APP_MODULE}.so"
          EOF
          
      - uses: actions/upload-artifact@v4
        with:
          name: compiled-${{ matrix.android_abi }}
          path: dist/*.so
          retention-days: 1

  build:
    needs: [config, compile]
    if: >-
      always() && needs.config.result == 'success' && 
      (inputs.enable_nuitka == false || needs.compile.result == 'success')
    runs-on: ubuntu-latest
    timeout-minutes: 45
    strategy:
      fail-fast: false
      matrix:
        include: ${{ fromJson(needs.config.outputs.build_matrix) }}
    steps:
      - uses: actions/checkout@v4
      - uses: actions/download-artifact@v4
        if: inputs.enable_nuitka != false
        with:
          name: compiled-${{ matrix.android_abi }}
          path: dist/${{ matrix.android_abi }}
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
      - name: Build frontend
        run: |
          cd frontend
          [[ -f package-lock.json ]] && npm ci || npm install
          npm run build
      - uses: actions/setup-python@v5
        with:
          python-version: ${{ needs.config.outputs.python_version }}
      - name: Install pyapp
        run: pip install "pyapp-cli[compile] @ git+https://github.com/Jzhenli/pyapp.git"
      - uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '17'
      - name: Build
        run: pyapp build android --arch ${{ matrix.android_abi }}
      - name: Compile with precompiled .so
        if: inputs.enable_nuitka != false
        run: |
          SO_FILE="dist/${{ matrix.android_abi }}/${{ needs.config.outputs.app_module }}.so"
          [ ! -f "$SO_FILE" ] && { echo "::error::.so not found: $SO_FILE"; exit 1; }
          pyapp compile android --precompiled "$SO_FILE"
      - name: Package APK
        run: pyapp package android
      - uses: actions/upload-artifact@v4
        with:
          name: ${{ needs.config.outputs.app_name }}-${{ needs.config.outputs.version }}-android-${{ matrix.apk_arch }}
          path: dist/*.apk
      - uses: actions/upload-artifact@v4
        if: failure()
        with:
          name: log-failure-${{ matrix.android_abi }}
          path: bundles/android/app/build/reports/
      - name: Summary
        if: always()
        run: |
          echo "### Android Build (${{ matrix.android_abi }})" >> $GITHUB_STEP_SUMMARY
          echo "- **Version**: ${{ needs.config.outputs.version }}" >> $GITHUB_STEP_SUMMARY
          echo "- **Arch**: ${{ matrix.android_abi }}" >> $GITHUB_STEP_SUMMARY
          echo "- **Nuitka**: ${{ inputs.enable_nuitka != false }}" >> $GITHUB_STEP_SUMMARY
{% endraw %}